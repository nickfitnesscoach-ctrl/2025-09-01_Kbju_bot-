# Конфигурация Telegram бота
TELEGRAM_BOT_TOKEN=0000000000:REPLACE_ME_WITH_YOUR_BOT_TOKEN
ADMIN_CHAT_ID=123456789

# URL базы данных (SQLite по умолчанию)
DB_URL=sqlite+aiosqlite:////app/data/db.sqlite3

# Webhook для интеграции с n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/kbju_leads
N8N_WEBHOOK_SECRET=your_webhook_secret_here

# Настройки админ-панели (Flask)
ADMIN_PASSWORD=your_admin_password
SECRET_KEY=your_secret_key_for_flask_sessions_here_make_it_long_and_random

# Проверка подписки на канал
ENABLE_SUBSCRIPTION_GATE=true
CHANNEL_URL=https://t.me/your_channel
CHANNEL_ID_OR_USERNAME=@your_channel
ALLOW_GATE_FALLBACK_PASS=false

# Feature toggles
ENABLE_DRIP_FOLLOWUPS=true
ENABLE_STALLED_REMINDER=true
ENABLE_HOT_LEAD_ALERTS=true
DEBUG=false

# Drip follow-up scheduler
DRIP_CHECK_INTERVAL_SEC=600
DRIP_STAGE_1_MIN=60
DRIP_STAGE_2_MIN=1440
DRIP_STAGE_3_MIN=2880
DRIP_STAGE_4_MIN=4320

# Reminder for unfinished calculations
STALLED_REMINDER_DELAY_MIN=120

# OpenRouter AI для персональных рекомендаций
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Обязательная подписка на канал (для AI-рекомендаций)
REQUIRED_CHANNEL_ID=@your_channel
REQUIRED_CHANNEL_URL=https://t.me/your_channel
